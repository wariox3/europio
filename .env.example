# Aplicación
APP_NAME=europio
ENVIRONMENT=development
DEBUG=true

# Base de datos PostgreSQL
DATABASE_URL=postgresql+psycopg://europio:europio@localhost:5432/europio

# WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=cambia_este_token_de_verificacion
WHATSAPP_API_VERSION=v21.0
# App Secret (Meta → App → Configuración → Básica) para verificar la firma del webhook
WHATSAPP_APP_SECRET=

# Clave para proteger /admin (envíala en el header X-API-Key). Usa una cadena larga y aleatoria.
ADMIN_API_KEY=
