[Unit]
Description=europio - Bot de soporte WhatsApp (FastAPI)
After=network.target postgresql.service
Wants=postgresql.service

[Service]
User=europio
Group=europio
WorkingDirectory=/opt/europio
EnvironmentFile=/opt/europio/.env
ExecStart=/opt/europio/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8053 --workers 2
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
